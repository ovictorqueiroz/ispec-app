<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradiente"
    tools:context=".CadastroEquipamentoActivity">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">


        <ImageView
            android:id="@+id/arrowLeft"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_arrow_left" />


        <TextView
            android:id="@+id/txtCadEquipamento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center"
            android:text="Cadastrar Equipamento"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_list"
            app:tint="@color/white" />

    </LinearLayout>

    <!-- BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_cinza_claro"
        app:elevation="8dp"
        app:itemIconTint="@color/cinzaEscuro"
        app:itemTextColor="@color/cinzaEscuro"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

    <!-- BODY: entre header e bottom nav -->
    <LinearLayout
        android:id="@+id/menuBody"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/header"
        android:background="@drawable/bg_cinza_claro"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="95dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <LinearLayout
                android:id="@+id/formContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- CAMPO: Nome -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Código do Cliente"
                    android:textColor="@color/vermelhoEscuro"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtIdCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_campos"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Código do Cliente"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white"
                    />

                <!-- CAMPO: Nome -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nome"
                    android:textColor="@color/vermelhoEscuro"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtNome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_campos"
                    android:hint="Nome do equipamento"
                    android:inputType="text"
                    android:padding="12dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white"

                    />

                <!-- CAMPO: Localização -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Localização"
                    android:textColor="@color/vermelhoEscuro"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtLocalizacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_campos"
                    android:hint="Localização do equipamento"
                    android:textColor="@color/white"
                    android:padding="12dp"
                    android:textColorHint="@color/white" />

                <!-- CAMPO: Data de Instalação -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Data de Instalação"
                    android:textColor="@color/vermelhoEscuro"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtDataInstalacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_campos"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="dd/mm/aaaa"
                    android:inputType="none"
                    android:padding="12dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white" />

                <!-- CAMPO: Status -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Status"
                    android:textColor="@color/vermelhoEscuro"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_campos"
                    android:padding="12dp"

                    />

                <!-- CAMPO: Tipo de Equipamento -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Tipo de Equipamento"
                    android:textColor="@color/vermelhoEscuro"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- CAMPOS: Extintor (visibilidade controlada pela Activity) -->
                <Spinner
                    android:id="@+id/spinnerTipo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_campos"
                    android:padding="12dp" />

                <LinearLayout
                    android:id="@+id/camposExtintor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Classe do Fogo"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerClasseFogo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_campos"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Capacidade (kg)"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtCapacidade"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_campos"
                        android:hint="Ex: 6.0"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Data de Validade"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtDataValidade"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_campos"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="dd/mm/aaaa"
                        android:inputType="none"
                        android:padding="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Pressão (bar)"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtPressao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_campos"
                        android:hint="Ex: 12"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white" />

                </LinearLayout>

                <!-- CAMPOS: Alarme -->
                <LinearLayout
                    android:id="@+id/camposAlarme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Tipo de Sensor"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerTipoSensor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_campos"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Última Verificação"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtUltimaVerificacao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_campos"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="dd/mm/aaaa"
                        android:inputType="none"
                        android:padding="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Funcionando"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Switch
                        android:id="@+id/switchFuncionando"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:checked="true" />
                </LinearLayout>

                <!-- CAMPOS: Hidrante -->
                <LinearLayout
                    android:id="@+id/camposHidrante"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Pressão da Água (bar)"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtPressaoAgua"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_campos"
                        android:hint="Ex: 5.0"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Comprimento da Mangueira (m)"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtCompMangueira"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_campos"
                        android:hint="Ex: 20.0"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Disponível"
                        android:textColor="@color/vermelhoEscuro"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Switch
                        android:id="@+id/switchDisponivel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:checked="true" />

                </LinearLayout>

                <!-- BOTÃO CADASTRAR -->
                <Button
                    android:id="@+id/btnCadastrar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/vermelhoClaro"
                    android:padding="14dp"
                    android:text="Cadastrar"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</RelativeLayout>