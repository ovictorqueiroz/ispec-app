<?xml version="1.0" encoding="utf-8"?>
<!-- Card para agendamentos da semana (Bloco 5).
     Exibe: Título, Responsável, Tipo, Data -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Título do agendamento -->
        <TextView
            android:id="@+id/tvAvisoAgendTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <!-- Responsável -->
        <TextView
            android:id="@+id/tvAvisoAgendResponsavel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="#666666" />

        <!-- Linha inferior: tipo + data -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvAvisoAgendTipo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/cinzaEscuro"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/tvAvisoAgendData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#666666" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
