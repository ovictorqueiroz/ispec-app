<?xml version="1.0" encoding="utf-8"?>
<!-- Card para equipamentos nos blocos 1, 2 e 3.
     Exibe: Código | Nome, Cliente, Data de validade -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- "EXT-001 | Extintor de Pó Químico" -->
        <TextView
            android:id="@+id/tvAvisoEquipCodNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <!-- Cliente -->
        <TextView
            android:id="@+id/tvAvisoEquipCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="#666666" />

        <!-- "Validade: 15/01/2026" -->
        <TextView
            android:id="@+id/tvAvisoEquipValidade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="@color/vermelhoClaro" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
