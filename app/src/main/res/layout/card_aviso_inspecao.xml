<?xml version="1.0" encoding="utf-8"?>
<!-- Card para inspeções reprovadas (Bloco 4).
     Exibe: Nome do equipamento, Cliente, Responsável, Data, Status: Reprovado -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Nome do equipamento -->
        <TextView
            android:id="@+id/tvAvisoInspEquipamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <!-- Cliente -->
        <TextView
            android:id="@+id/tvAvisoInspCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="#666666" />

        <!-- Responsável -->
        <TextView
            android:id="@+id/tvAvisoInspResponsavel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="#666666" />

        <!-- Linha inferior: data + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvAvisoInspData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvAvisoInspStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/vermelhoClaro" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
