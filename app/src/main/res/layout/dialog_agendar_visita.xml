<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título do dialog -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agendar visita"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/cinzaEscuro"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Linha 1: Tipo | Título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Spinner Tipo -->
            <Spinner
                android:id="@+id/spinnerTipo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_campos_white"
                android:padding="6dp"
                android:layout_marginEnd="8dp" />

            <!-- Título / Razão Social -->
            <EditText
                android:id="@+id/etTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:background="@drawable/bg_campos_white"
                android:hint="Razão social / título"
                android:inputType="text"
                android:padding="10dp"
                android:maxLines="1" />

        </LinearLayout>

        <!-- Linha 2: Data -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnEscolherData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escolher data"
                android:backgroundTint="@color/vermelhoEscuro"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvDataSelecionada"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nenhuma data selecionada"
                android:textSize="14sp"
                android:textColor="@color/cinzaEscuro" />

        </LinearLayout>

        <!-- Linha 3: Responsável -->
        <Spinner
            android:id="@+id/spinnerResponsavel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_campos_white"
            android:padding="6dp"
            android:layout_marginBottom="12dp" />

        <!-- Linha 4: Status -->
        <Spinner
            android:id="@+id/spinnerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_campos_white"
            android:padding="6dp"
            android:layout_marginBottom="20dp" />

        <!-- Botão Agendar -->
        <Button
            android:id="@+id/btnSalvarAgendamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agendar"
            android:backgroundTint="@color/vermelhoEscuro"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
