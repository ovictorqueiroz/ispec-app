<?xml version="1.0" encoding="utf-8"?>
<!-- Cabeçalho de seção na lista de Avisos.
     Ex: "Equipamentos Vencidos" em vermelho + "Vencidos: 12" -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="18dp"
    android:paddingBottom="6dp"
    android:gravity="center_vertical">

    <!-- Barra colorida lateral -->
    <View
        android:layout_width="4dp"
        android:layout_height="32dp"
        android:layout_marginEnd="10dp"
        android:background="@color/vermelhoClaro" />
    <!-- A cor da barra é programaticamente sobrescrita pelo adapter via tint ou background -->

    <!-- Título da seção -->
    <TextView
        android:id="@+id/tvAvisoHeaderTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/cinzaEscuro" />

    <!-- KPI numérico (ex: "Vencidos: 12") -->
    <TextView
        android:id="@+id/tvAvisoHeaderKpi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
